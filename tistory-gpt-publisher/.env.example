# Environment variables
# Copy this file to .env and fill values locally or in Vercel/GitHub Secrets.
APP_BASE_URL=https://your-vercel-domain.vercel.app
APP_API_KEY=change-this-api-key
WORKER_SECRET=change-this-worker-secret
DATABASE_URL=postgresql://user:password@host:5432/db?schema=public
GITHUB_REPO=khs0927/Naver_Blog
GITHUB_PAT=YOUR_GITHUB_PAT_HERE
TISTORY_BLOG_NAME=yourblog
TISTORY_BLOG_URL=https://yourblog.tistory.com
TISTORY_COOKIE_JSON=YOUR_TISTORY_COOKIE_JSON_HERE
TISTORY_DEFAULT_CATEGORY=
TISTORY_DEFAULT_VISIBILITY=private
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4.1-mini
